  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=payload.cli.config.mjs payload",
    "lint": "eslint .",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "clean": "rm -rf .next",
    "build:analyze": "ANALYZE=true next build",
    "seed:integrations": "node scripts/seed-integrations.mjs",
    "seed:legal-pages": "node scripts/seed-legal-pages.mjs",
    "migrate:legacy-data": "bun scripts/migrate-legacy-data.mjs",
    "images:compress:overwrite": "node scripts/compress-images.mjs --overwrite",
    "api:twenty:pull-openapi": "node scripts/fetch-twenty-openapi.mjs",
    "api:twenty:generate": "npm run api:twenty:pull-openapi && orval --config orval.config.cjs && node scripts/mark-generated-twenty-no-check.mjs"
  },
