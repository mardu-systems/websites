{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APP_URL",
    "DATABASE_URI",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "DATA_DIR",
    "EMAIL_FROM",
    "EMAIL_TO",
    "MARDU_PLATFORM_ORIGIN",
    "NEON_PROJECT_ID",
    "NEWSLETTER_SECRET",
    "NEXT_PUBLIC_GOOGLE_MEASUREMENT_ID",
    "NEXT_PUBLIC_RECAPTCHA_SITE_KEY",
    "OIDC_ALLOWED_EMAILS",
    "OIDC_ALLOWED_EMAIL_DOMAINS",
    "OIDC_AUTO_CREATE_USERS",
    "OIDC_CLIENT_ID",
    "OIDC_CLIENT_SECRET",
    "OIDC_DEBUG",
    "OIDC_ISSUER",
    "OIDC_REDIRECT_URI",
    "OIDC_SESSION_SECRET",
    "PAYLOAD_PUBLIC_SERVER_URL",
    "PAYLOAD_SECRET",
    "PGDATABASE",
    "PGHOST",
    "PGHOST_UNPOOLED",
    "PGPASSWORD",
    "PGUSER",
    "POSTGRES_DATABASE",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_PRISMA_URL",
    "POSTGRES_URL",
    "POSTGRES_URL_NO_SSL",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_USER",
    "RECAPTCHA_SECRET_KEY",
    "RESEND_API_KEY",
    "SPACE_SUBSCRIBERS_EXPORT",
    "TWENTY_API_BASE_URL",
    "TWENTY_API_KEY",
    "TWENTY_OPENAPI_BASE_URL",
    "TWENTY_OPENAPI_FETCH_TIMEOUT_MS",
    "TWENTY_OPENAPI_FILTER_MODE",
    "TWENTY_OPENAPI_OUTPUT",
    "TWENTY_OPENAPI_PATH",
    "TWENTY_OPENAPI_SCHEMAS",
    "TWENTY_OPENAPI_TAGS",
    "TWENTY_OPENAPI_TOKEN",
    "TWENTY_OPENAPI_URL",
    "TWENTY_OPENAPI_USE_DEFAULT_TAG_FILTER",
    "TWENTY_SYNC_RETRIES",
    "TWENTY_SYNC_TIMEOUT_MS"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "outputs": []
    },
    "type-check": {
      "dependsOn": [
        "^type-check"
      ],
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "build:analyze": {
      "cache": false
    }
  }
}
